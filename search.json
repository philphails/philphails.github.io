---
layout: null
permalink: /search.json
---

[
{% for episode in site.episodes %}
{
  "title": {{ episode.title | jsonify }},
  "excerpt": {{ episode.excerpt | strip_html | jsonify }},
  "url": {{ episode.url | relative_url | jsonify }},
  "teaser": {{ episode.header.teaser | default: episode.teaser | default: "" | jsonify }},
  "guest": {{ episode.guest | default: "" | jsonify }},
  "episode_number": {{ episode.episode_number }},
  "categories": {{ episode.categories | default: [] | jsonify }},
  "tags": {{ episode.tags | default: [] | jsonify }},
  "content": {{ episode.content | strip_html | normalize_whitespace | jsonify }}
}
{% unless forloop.last %},{% endunless %}
{% endfor %}
]